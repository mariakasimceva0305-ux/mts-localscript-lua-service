# Имя Docker Compose-проекта: одинаковые volumes на всех машинах и при любой имени папки с кодом.
# Не меняйте без необходимости: другое имя → новые volumes (ollama_data, …) → повторная загрузка моделей.
# Приоритет имени проекта у Docker Compose: флаг -p > COMPOSE_PROJECT_NAME > поле `name:` в compose > имя каталога.
COMPOSE_PROJECT_NAME=localscript

# Компилятор Lua 5.5 в образе api (см. api/Dockerfile). На стенде можно переопределить при нестандартном layout.
LUAC_BIN=/usr/local/bin/luac

# URL Ollama для контейнера api при запуске через docker compose.
# Оставьте http://ollama:11434 — это имя сервиса внутри compose-сети.
# НЕ задавайте http://127.0.0.1:11434 здесь: из контейнера api это не хост-машина.
OLLAMA_BASE_URL=http://ollama:11434

# Основная и запасная модель: сервис ollama-pull в docker compose подтягивает обе при старте
# (идемпотентно). Имена должны совпадать с тегами в библиотеке Ollama.
MODEL_NAME=qwen2.5-coder:7b
FALLBACK_MODEL=deepseek-coder:6.7b

# Размер контекста для Ollama options.num_ctx
CONTEXT_SIZE=4096

# Макс. токенов ответа (freeze; при обрыве ```lua — точечно поднимите, напр. 320–384)
OLLAMA_NUM_PREDICT=288

# Retrieval: сколько чанков в системный промпт (freeze)
RETRIEVAL_TOP_K=4

# 1 = короче инструкция к «плану» перед ```lua (см. prompts.py plan_instruction_line)
GENERATION_COMPACT_PLAN=1

# Read-timeout одного HTTP-запроса api → Ollama (секунды). Два подряд таймаута (primary+fallback) ≈ 2× это значение.
# 240 — после аудита freeze (220): меньше ложных ReadTimeout на длинной генерации без смены pipeline.
OLLAMA_HTTP_TIMEOUT_S=240

# RETRIEVAL_DEBUG=1 — поле retrieval_debug в POST /generate

# Если при docker compose build падает SSL к PyPI — попробуйте зеркало, например:
# PIP_INDEX_URL=https://mirrors.aliyun.com/pypi/simple/
# или скачайте wheel на хосте: scripts\download_wheels.ps1
PIP_INDEX_URL=https://pypi.org/simple

# Eval на хосте: рекомендуемый таймаут на один кейс (передаётся в httpx, не в api):
#   python -u tests/run_eval.py --base-url http://127.0.0.1:8000 --timeout 720
