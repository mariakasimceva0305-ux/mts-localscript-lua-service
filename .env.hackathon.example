# Пример переменных при использовании docker-compose.hackathon.yml.
# Числовые лимиты инференса для api дублируются в override-файле; здесь — для документации
# и на случай локального запуска api без второго compose-файла.
#
# docker compose -f docker-compose.yml -f docker-compose.hackathon.yml up --build

OLLAMA_BASE_URL=http://ollama:11434
MODEL_NAME=qwen2.5-coder:7b
FALLBACK_MODEL=deepseek-coder:6.7b

CONTEXT_SIZE=4096
OLLAMA_NUM_PREDICT=256
RETRIEVAL_TOP_K=4
GENERATION_COMPACT_PLAN=1
OLLAMA_HTTP_TIMEOUT_S=240

# На стороне контейнера ollama (см. docker-compose.hackathon.yml):
# OLLAMA_NUM_PARALLEL=1

PIP_INDEX_URL=https://pypi.org/simple
